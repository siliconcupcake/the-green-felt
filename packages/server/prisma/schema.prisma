datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Player {
  id        String   @id @map("_id")    // UUID, not ObjectId — matches playerId from lobby
  name      String
  updatedAt DateTime @updatedAt
}

model Game {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  roomCode       String   @unique
  gameTypeId     String
  hostPlayerId   String
  players        String[]         // Player IDs
  status         String   @default("waiting") // waiting | in_progress | finished
  inLobby        Boolean  @default(true)
  state          Json?            // Full game state (null during lobby)
  actionLog      Json[]   @default([])
  result         Json?            // GameResult (null until finished)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime         // TTL for auto-cleanup
}
